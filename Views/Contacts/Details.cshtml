@model PhoneBook.Models.Contact

@{
    ViewData["Title"] = "Details";

    string fullImageSrc = "/images/default_contact.png";

    if (Model.Picture?.ImageData != null)
    {
        string mime = Model.Picture.ContentType;
        string base64 = Convert.ToBase64String(Model.Picture.ImageData);
        fullImageSrc = $"data:{mime};base64,{base64}";
    }
}

<h2 class="mb-4">Contact Details</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <img src="@fullImageSrc"
             class="img-fluid rounded border"
             style="max-height:350px; object-fit:cover;"
             alt="Contact picture" />
    </div>

    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">Name</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">Phone</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">Email</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">Birthday</dt>
            <dd class="col-sm-9">@Model.Birthday</dd>
        </dl>

        <div class="mt-3">
            <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@Url.Action("Details")" asp-route-returnId="@Model.Id">Edit</a>
            <a class="btn btn-info" href="@ViewBag.ReturnUrl">Back to List</a>
        </div>
    </div>
</div>
