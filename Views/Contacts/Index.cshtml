@model IEnumerable<PhoneBook.Models.Contact>

<h2>Phonebook</h2>

<a class="btn btn-primary" href="/Contacts/Create">Add New Contact</a>

<table class="table table-bordered table-striped mt-3">
    <tr>
        <th>Picture</th>
        <th>Name</th>
        <th>Phone</th>
        <th>Email</th>
        <th>Birthday</th>
        <th></th>
    </tr>

    @foreach (var item in Model)
    {
    
        string base64Image;

        if (item.Picture != null && item.Picture.ImageData != null)
        {
            string mimeType = item.Picture.ContentType; // example: "image/jpeg"
            string base64 = Convert.ToBase64String(item.Picture.ImageData);
            base64Image = $"data:{mimeType};base64,{base64}";
        }
        else
        {
            base64Image = "/images/default_contact.png";
        }

        <tr>
            <td>
                <img src= @base64Image
                     style="width:60px; height:60px; object-fit:cover; border-radius:5px;" />
            </td>
            <td>@item.Name</td>
            <td>@item.Phone</td>
            <td>@item.Email</td>
            <td>@item.Birthday?.ToShortDateString()</td>
            <td>
                <a class="btn btn-secondary" href="/Contacts/Edit/@item.Id">Edit</a>
                <a class="btn btn-info" href="/Contacts/Details/@item.Id">Details</a>
                <a class="btn btn-outline-danger" href="/Contacts/Delete/@item.Id">Delete</a>
            </td>
        </tr>
    }
</table>
