@model PhoneBook.Web.ViewModels.Contacts.ContactCreateViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["PageTitle"];
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="mb-4">
                <h1 class="text-primary mb-2">@Localizer["HeadingCreate"]</h1>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">@Localizer["HeadingContact"]</h5>
                </div>

                <form asp-action="Create" method="post" enctype="multipart/form-data" class="needs-validation" novalidate>
                    @Html.AntiForgeryToken()

                    <div class="card-body">
                        <!-- Name Field -->
                        <div class="mb-3">
                            <label asp-for="Name" class="form-label">@Localizer["TableHeaderName"]</label>
                            <input asp-for="Name" class="form-control" placeholder=@Localizer["TableHeaderName"] />
                            <span asp-validation-for="Name" class="text-danger"></span>
                        </div>

                        <!-- Phone Field -->
                        <div class="mb-3">
                            <label asp-for="Phone" class="form-label">@Localizer["TableHeaderPhone"]</label>
                            <input asp-for="Phone" class="form-control" placeholder=@Localizer["TableHeaderPhone"] />
                            <span asp-validation-for="Phone" class="text-danger"></span>
                        </div>

                        <!-- Email Field -->
                        <div class="mb-3">
                            <label asp-for="Email" class="form-label">@Localizer["TableHeaderEmail"]</label>
                            <input asp-for="Email" class="form-control" placeholder=@Localizer["TableHeaderEmail"] />
                            <span asp-validation-for="Email" class="text-danger"></span>
                        </div>

                        <!-- Birthday Field -->
                        <div class="mb-3">
                            <label asp-for="Birthday" class="form-label">@Localizer["TableHeaderBirthday"]</label>
                            <input asp-for="Birthday" class="form-control" type="date" />
                            <span asp-validation-for="Birthday" class="text-danger"></span>
                        </div>

                        <hr />

                        <!-- Picture Section -->
                        <div class="mb-3">
                            <label class="form-label fw-semibold">@Localizer["HeadingPicture"]</label>

                            <!-- Preview -->
                            <div class="mb-3 text-center">
                                <img id="preview" src="~/images/default_contact.png"
                                     class="rounded border border-2 border-light"
                                     style="width:200px; height:200px; object-fit:cover; box-shadow: 0 2px 8px rgba(0,0,0,0.1);"
                                     alt=@Localizer["AltPreview"] />
                            </div>

                            <!-- File Input -->
                            <div class="mb-2">
                                <input type="file" id="fileInput" name="Picture" class="form-control" accept="image/*" />
                                <small class="form-text text-muted d-block mt-2">@Localizer["TextPicture"]</small>
                            </div>

                            <!-- Clear Button -->
                            <button type="button" id="clearFile" class="btn btn-outline-secondary btn-sm">
                                <i class="bi bi-x-circle"></i> @Localizer["ButtonRemove"]
                            </button>
                        </div>
                    </div>

                    <!-- Form Footer -->
                    <div class="card-footer bg-light">
                        <input type="hidden" asp-for="ReturnUrl" />
                        <div class="d-flex gap-2 justify-content-between">
                            <a href="@ViewBag.ReturnUrl" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> @Localizer["ButtonBack"]
                            </a>
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> @Localizer["ButtonSave"]
                            </button>
                        </div>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
    <script>
        (function() {
            const fileInput = document.getElementById('fileInput');
            const preview = document.getElementById('preview');
            const clearBtn = document.getElementById('clearFile');

            fileInput.addEventListener('change', function(e) {
                const file = this.files && this.files[0];
                if (!file) {
                    preview.src = '@Url.Content("~/images/default_contact.png")';
                    return;
                }

                if (!file.type.startsWith('image/')) {
                    alert('Please select an image file.');
                    fileInput.value = '';
                    preview.src = '@Url.Content("~/images/default_contact.png")';
                    return;
                }

                const reader = new FileReader();
                reader.onload = function(ev) {
                    preview.src = ev.target.result;
                };
                reader.readAsDataURL(file);
            });

            clearBtn.addEventListener('click', function() {
                fileInput.value = '';
                preview.src = '@Url.Content("~/images/default_contact.png")';
            });
        })();
    </script>
}
