@model IEnumerable<PhoneBook.Domain.Models.Contact>
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<div class="d-flex justify-content-between align-items-center mb-4">
    <h2 class="mb-0">Gallery</h2>

    <div>
        <a class="btn btn-success me-2" asp-action="Index">@Localizer["ListViewButton"]</a>
        <a class="btn btn-primary" asp-action="Create" asp-route-returnUrl="@Url.Action("Gallery")">@Localizer["AddContactButton"]</a>
    </div>
</div>

<div class="row row-cols-2 row-cols-sm-3 row-cols-md-4 g-3">
    @foreach (var contact in Model)
    {
        string thumbSrc = "/images/default_contact.png";

        if (contact.Picture?.ThumbnailData != null)
        {
            string base64 = Convert.ToBase64String(contact.Picture.ThumbnailData);
            thumbSrc = $"data:{contact.Picture.ContentType};base64,{base64}";
        }

        <div class="col">
            <div class="card h-100 text-center">
                <a asp-action="Details" asp-route-id="@contact.Id" asp-route-returnUrl="@Url.Action("Gallery")" class="text-decoration-none">
                    <img src="@thumbSrc"
                         class="card-img-top"
                         style="height:150px; object-fit:contain;" />

                    <div class="card-body">
                        <h6 class="card-title mb-0">@contact.Name</h6>
                    </div>
                </a>
            </div>
        </div>
    }
</div>
