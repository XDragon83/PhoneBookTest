@model PhoneBook.Web.ViewModels.Contacts.ContactGalleryViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = Localizer["PageTitle"];
}

<div class="container-fluid mt-4">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="mb-0">@Localizer["GalleryViewButton"]</h1>
            <p class="text-muted fs-6">@Model.ContactsCount @Localizer["Contact"]</p>
        </div>

        <div class="d-flex gap-2">
            <a class="btn btn-success" asp-action="Index">
                <i class="bi bi-list-ul"></i> @Localizer["ListViewButton"]
            </a>
            <a class="btn btn-primary" asp-action="Create" asp-route-returnUrl="@Url.Action("Gallery")">
                <i class="bi bi-plus-circle"></i> @Localizer["AddContactButton"]
            </a>
        </div>
    </div>

    @if (Model.Contacts.Any())
    {
        <div class="row row-cols-1 row-cols-sm-2 row-cols-md-3 row-cols-lg-4 row-cols-xl-5 g-3">
            @foreach (var contact in Model.Contacts)
            {
                string thumbSrc = "/images/default_contact.png";

                if (contact.ThumbnailBase64 != null)
                {
                    thumbSrc = $"data:image/jpeg;base64,{contact.ThumbnailBase64}";
                }

                <div class="col">
                    <a asp-action="Details" asp-route-id="@contact.Id" asp-route-returnUrl="@Url.Action("Gallery")" class="text-decoration-none">
                        <div class="card h-100 shadow-sm border-0 overflow-hidden" style="transition: transform 0.2s, box-shadow 0.2s;">
                            <img src="@thumbSrc"
                                 class="card-img-top"
                                 style="height: 200px; object-fit: cover;" 
                                 alt="@contact.Name" />
                            <div class="card-body">
                                <h6 class="card-title mb-0 text-dark">@contact.Name</h6>
                            </div>
                            <div class="card-footer bg-transparent border-top">
                                <small class="text-muted">@contact.Phone</small>
                            </div>
                        </div>
                    </a>
                </div>
            }
        </div>
    }
    else
    {
        <div class="alert alert-info text-center py-5" role="alert">
            <i class="bi bi-inbox" style="font-size: 3rem;"></i>
            <h4 class="mt-3">@Localizer["NoContacts"]</h4>
            <p>@Localizer["AddContactButton"]</p>
            <a class="btn btn-primary" asp-action="Create" asp-route-returnUrl="@Url.Action("Gallery")">
                <i class="bi bi-plus-circle"></i> @Localizer["AddContactButton"]
            </a>
        </div>
    }
</div>

<style>
    .card {
        cursor: pointer;
    }

    .card:hover {
        transform: translateY(-5px);
        box-shadow: 0 8px 16px rgba(0, 0, 0, 0.15) !important;
    }

    .card-img-top {
        transition: transform 0.3s ease;
    }

    .card:hover .card-img-top {
        transform: scale(1.05);
    }
</style>
