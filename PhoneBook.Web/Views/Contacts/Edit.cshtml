@model PhoneBook.Domain.Models.Contact
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["PageTitle"];
}

<h2>@Localizer["HeadingEdit"]</h2>

<form asp-action="Edit" method="post">
    <input type="hidden" asp-for="Id" />

    <div class="form-group">
        <label asp-for="Name">@Localizer["TableHeaderName"]</label>
        <input asp-for="Name" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Phone">@Localizer["TableHeaderPhone"]</label>
        <input asp-for="Phone" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Email">@Localizer["TableHeaderEmail"]</label>
        <input asp-for="Email" class="form-control" />
    </div>

    <div class="form-group">
        <label asp-for="Birthday">@Localizer["TableHeaderBirthday"]</label>
        <input asp-for="Birthday" type="date" class="form-control" />
    </div>

    <br />

    <button type="submit" class="btn btn-primary">@Localizer["ButtonSave"]</button>
    <a href="@ViewBag.ReturnUrl" class="btn btn-secondary">@Localizer["ButtonBack"]</a>
</form>

<hr />

<h4>@Localizer["TableHeaderPicture"]</h4>

@if (Model.Picture != null)
{
    string base64Image;
    string mimeType = Model.Picture.ContentType; // example: "image/jpeg"
    string base64 = Convert.ToBase64String(Model.Picture.ImageData);
    base64Image = $"data:{mimeType};base64,{base64}";

    <div style="margin-bottom:10px;">
        <img src=@base64Image
             style="width:150px; height:150px; object-fit:cover; border-radius:8px; border:1px solid #ccc;" />
    </div>

    <!-- Separate form to delete picture -->
    <form asp-action="DeleteImage" asp-controller="Contacts" method="post">
        <input type="hidden" name="id" value="@Model.Id" />
        <button type="submit" class="btn btn-outline-danger">@Localizer["ButtonDeletePicture"]</button>
    </form>

    <br />
    <br />
    <!-- Separate form to replace existing picture -->
    <form asp-action="EditImage" asp-controller="Contacts" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-group">
            <label>@Localizer["ButtonReplacePicture"]</label>
            <input type="file" name="file" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">@Localizer["ButtonReplacePicture"]</button>
    </form>
}
else
{
    <!-- No picture: allow upload -->
    <form asp-action="EditImage" asp-controller="Contacts" method="post" enctype="multipart/form-data">
        <input type="hidden" name="id" value="@Model.Id" />
        <div class="form-group">
            <label>@Localizer["ButtonUploadPicture"]</label>
            <input type="file" name="file" class="form-control" />
        </div>
        <button type="submit" class="btn btn-primary">@Localizer["ButtonUploadPicture"]</button>
    </form>
}

@section Scripts {
    @{
        await Html.RenderPartialAsync("_ValidationScriptsPartial");
    }
}