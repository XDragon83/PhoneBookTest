@model PhoneBook.Services.DTOs.Contact.ContactDetailsDto
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["PageTitle"];

    string fullImageSrc = "/images/default_contact.png";

    if (Model.PictureBase64 != null)
    {
        string mime = Model.PictureMimeType != null ? Model.PictureMimeType : "image/jpeg";
        fullImageSrc = $"data:{mime};base64,{Model.PictureBase64}";
    }
}

<h2 class="mb-4">@Localizer["HeadingContact"]</h2>

<div class="row mb-4">
    <div class="col-md-4">
        <img src="@fullImageSrc"
             class="img-fluid rounded border"
             style="max-height:350px; object-fit:cover;"
             alt=@Localizer["AltPicture"] />
    </div>

    <div class="col-md-8">
        <dl class="row">
            <dt class="col-sm-3">@Localizer["TableHeaderName"]</dt>
            <dd class="col-sm-9">@Model.Name</dd>

            <dt class="col-sm-3">@Localizer["TableHeaderPhone"]</dt>
            <dd class="col-sm-9">@Model.Phone</dd>

            <dt class="col-sm-3">@Localizer["TableHeaderEmail"]</dt>
            <dd class="col-sm-9">@Model.Email</dd>

            <dt class="col-sm-3">@Localizer["TableHeaderBirthday"]</dt>
            <dd class="col-sm-9">@Model.Birthday?.ToShortDateString()</dd>
        </dl>

        <div class="mt-3">
            <a class="btn btn-secondary" asp-action="Edit" asp-route-id="@Model.Id" asp-route-returnUrl="@Url.Action("Details")" asp-route-returnId="@Model.Id">@Localizer["ButtonEdit"]</a>
            <a class="btn btn-info" href="@ViewBag.ReturnUrl">@Localizer["ButtonBack"]</a>
        </div>
    </div>
</div>
