@model PhoneBook.Web.ViewModels.Contacts.ContactDetailsViewModel
@using Microsoft.AspNetCore.Mvc.Localization
@inject IViewLocalizer Localizer

@{
    ViewData["Title"] = @Localizer["PageTitle"];

    string fullImageSrc = "/images/default_contact.png";

    if (Model.Contact.PictureBase64 != null)
    {
        string mime = Model.Contact.PictureMimeType != null ? Model.Contact.PictureMimeType : "image/jpeg";
        fullImageSrc = $"data:{mime};base64,{Model.Contact.PictureBase64}";
    }
}

<div class="container mt-4">
    <div class="row">
        <div class="col-lg-8">
            <div class="mb-4">
                <h1 class="text-primary mb-2">@Localizer["HeadingContact"]</h1>
                <p class="text-muted fs-6">@Html.DisplayFor(model => model.Contact.Phone)</p>
            </div>

            <div class="card shadow-sm">
                <div class="card-header bg-primary text-white">
                    <h5 class="mb-0">@Html.DisplayFor(model => model.Contact.Name)</h5>
                </div>

                <!-- Full Size Picture -->
                <div class="card-body text-center">
                    <img src="@fullImageSrc"
                         class="img-fluid rounded border border-2"
                         style="max-height: 500px; object-fit: cover; box-shadow: 0 4px 8px rgba(0,0,0,0.1);"
                         alt=@Localizer["AltPicture"] />
                </div>

                <!-- Contact Information -->
                <div class="card-body">
                    <div class="row mb-3">
                        <div class="col-md-6 mb-3">
                            <div class="p-3 bg-light rounded">
                                <h6 class="text-secondary mb-2">@Localizer["TableHeaderPhone"]</h6>
                                <p class="fs-5 fw-semibold mb-0">@Html.DisplayFor(model => model.Contact.Phone)</p>
                            </div>
                        </div>
                        <div class="col-md-6 mb-3">
                            <div class="p-3 bg-light rounded">
                                <h6 class="text-secondary mb-2">@Localizer["TableHeaderEmail"]</h6>
                                <p class="fs-5 mb-0">
                                    @if (!string.IsNullOrEmpty(Model.Contact.Email))
                                    {
                                        <a href="mailto:@Model.Contact.Email">@Html.DisplayFor(model => model.Contact.Email)</a>
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>

                    <div class="row">
                        <div class="col-12">
                            <div class="p-3 bg-light rounded">
                                <h6 class="text-secondary mb-2">@Localizer["TableHeaderBirthday"]</h6>
                                <p class="fs-5 mb-0">
                                    @if (Model.Contact.Birthday.HasValue)
                                    {
                                        @Model.Contact.Birthday.Value.ToShortDateString()
                                    }
                                    else
                                    {
                                        <span class="text-muted">-</span>
                                    }
                                </p>
                            </div>
                        </div>
                    </div>
                </div>

                <!-- Actions Footer -->
                <div class="card-footer bg-light">
                    <div class="d-flex gap-2 justify-content-between">
                        <a href="@ViewBag.ReturnUrl" class="btn btn-outline-secondary">
                            <i class="bi bi-arrow-left"></i> @Localizer["ButtonBack"]
                        </a>
                        <div class="d-flex gap-2">
                            <a class="btn btn-primary" asp-action="Edit" asp-route-id="@Model.Contact.Id" asp-route-returnUrl="@ViewBag.ReturnUrl">
                                <i class="bi bi-pencil"></i> @Localizer["ButtonEdit"]
                            </a>
                            <a class="btn btn-outline-danger" asp-action="Delete" asp-route-id="@Model.Contact.Id" asp-route-returnUrl="@ViewBag.ReturnUrl">
                                <i class="bi bi-trash"></i> @Localizer["ButtonDelete"]
                            </a>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </div>
</div>
